<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="FuelFinder.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:FuelFinder"
    xmlns:views="clr-namespace:FuelFinder.Views" 
    Title="FuelFinder"
    FlyoutBehavior="Flyout">
    

    <Shell.FlyoutHeader>
        <VerticalStackLayout Padding="20" BackgroundColor="BlueViolet">
            <Label Text="FuelFinder" FontSize="20" TextColor="White" FontAttributes="Bold" />

            <Label Text="{Binding TotalPoints, StringFormat='Dina poäng: {0}'}"
                   TextColor="DeepSkyBlue"
                   FontSize="14"
                   FontAttributes="Bold"></Label>
        </VerticalStackLayout>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Bränsle" FlyoutIcon="gas.png" FlyoutDisplayOptions="AsSingleItem">
        <ShellContent Route="MainPage" 
                      ContentTemplate="{DataTemplate views:MainPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Trafik" Icon="traffic.png">
        <ShellContent Route="TrafficPage"
                      ContentTemplate="{DataTemplate views:TrafficPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Kalkylator" Icon="calc.png">
        <ShellContent Route="CalculatorPage"
                      ContentTemplate="{DataTemplate views:CalculatorPage}"/>
    </FlyoutItem>

    <FlyoutItem Title="Loggbok" Icon="note.png">
        <ShellContent Route="FuelLogPage"
                      ContentTemplate="{DataTemplate views:FuelLogPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Karta" Icon="map.png">
        <ShellContent Route="MapPage"
                      ContentTemplate="{DataTemplate views:MapPage}" />
    </FlyoutItem>

</Shell>
    
    
