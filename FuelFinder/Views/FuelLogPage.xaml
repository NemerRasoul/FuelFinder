<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FuelFinder.Views.FuelLogPage"
             Title="Tankningslogg">
    <VerticalStackLayout Padding="20" Spacing="15" BackgroundColor="Black">
        
        <Label 
            Text="Logga ny tankning"
            FontSize="24"
            FontAttributes="Bold"
            TextColor="White" />
        
        <Entry 
            Placeholder="Station (t.ex Circle K)"
            x:Name="StationEntry"
            TextColor="White"
            PlaceholderColor="Gray"/>
        
        <Entry
            Placeholder="Antal liter"
            x:Name="LitersEntry"
            Keyboard="Numeric"
            TextColor="White"/>
        
        <Entry 
            Placeholder="Mätarställning (km)"
            x:Name="OdometerEntry"
            Keyboard="Numeric"
            PlaceholderColor="Gray"/>
        
        <Button
            Text="Spara i loggboken"
            Clicked="OnSaveLogClicked"
            BackgroundColor="BlueViolet"/>
        <Border HeightRequest="1" BackgroundColor="Gray" Margin="0,10"/>
        
        <Label 
            Text="Historik och Bränsle Förbrukning"
            FontSize="20"
            FontAttributes="Bold"
            TextColor="White" />
        
        <CollectionView x:Name="LogCollection">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    
                    <Border Margin="0,5" Padding="10" BackgroundColor="Black">
                        <HorizontalStackLayout Spacing="20">
                            
                            <VerticalStackLayout>
                                <Label Text="{Binding Date, StringFormat='{0:yyyy-MM-dd}'}" TextColor="Gray" FontSize="10"/>
                                <Label Text="{Binding StationName}" TextColor="White" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            
                            <VerticalStackLayout HorizontalOptions="EndAndExpand">
                                <Label Text="{Binding Consumption, StringFormat='{0:F2} L/mil'}" TextColor="LawnGreen" FontSize="18"/>
                                <Label Text="{Binding Odometer, StringFormat='{0} km'}" TextColor="Gray" FontSize="12"/>
                            </VerticalStackLayout>
                            
                        </HorizontalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>