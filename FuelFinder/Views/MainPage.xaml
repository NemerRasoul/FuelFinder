<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FuelFinder.ViewModels"
             x:Class="FuelFinder.Views.MainPage"
             Title="Bensinpriser"
             BackgroundColor="Black">


    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <Button Grid.Row="0" Text="Välj Län"
            Clicked="OnSelectCountyClicked"
            BackgroundColor="BlueViolet"
            TextColor="White"
            Margin="10" />

        <SearchBar Grid.Row="1" Placeholder="Sök stad..."
               Text="{Binding SearchText}"
               SearchCommand="{Binding LoadDataCommand}"
               TextColor="White"
               PlaceholderColor="Gray"
               Margin="10" />

        <Border Grid.Row="2" BackgroundColor="Black"
            Margin="10" Padding="10"
            StrokeShape="RoundRectangle 10"
            Stroke="Transparent">
            <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                <Label Text="{Binding WeatherInfo}" TextColor="White" FontAttributes="Bold" />
                <Label Text="{Binding WeatherWarning}" TextColor="Yellow" FontAttributes="Bold" />
            </HorizontalStackLayout>
        </Border>

        <RefreshView Grid.Row="3"
                 IsRefreshing="{Binding IsRefreshing}"
                 Command="{Binding LoadDataCommand}">
            
            <VerticalStackLayout>
                <Picker Title="Välj bränsle"
                    ItemsSource="{Binding FuelTypes}"
                    SelectedItem="{Binding SelectedFuelType}"
                    TextColor="White"
                    TitleColor="Gray"
                    BackgroundColor="Black"
                    Margin="10"/>
                
                <CollectionView ItemsSource="{Binding Stations}" HeightRequest="500">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Padding="10">
                                <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold" />
                                <Label Text="{Binding Price}" TextColor="LawnGreen" FontAttributes="Bold" />
                                <Label Text="{Binding StatusText}" TextColor="Red" FontSize="12" FontAttributes="Italic" />
                                
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </RefreshView>

    </Grid>
</ContentPage>