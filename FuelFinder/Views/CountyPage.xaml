<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FuelFinder.Views.CountyPage"
             Title="Välj län"
             BackgroundColor="Black">
    
   
        <CollectionView ItemsSource="{Binding Counties}"
                        SelectionMode="Single"
                        SelectionChanged="OnCountySelected">
            
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <StackLayout 
                        Padding="15">
                        
                    <Label Text="{Binding Name}"
                               TextColor="White"
                               FontSize="18"
                               FontAttributes="Bold"
                           
                       ></Label>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

</ContentPage>